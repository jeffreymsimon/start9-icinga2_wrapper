#!/bin/bash
# check_cloudflare_tunnel - Nagios-compatible check for Cloudflare Tunnel health
#
# Queries the Cloudflare API to verify tunnel status and active connections.
#
# Usage:
#   check_cloudflare_tunnel -T <tunnel_id> -f <config_file> [-w <warn>] [-c <crit>]
#   check_cloudflare_tunnel -T <tunnel_id> -t <api_token> -a <account_id> [-w <warn>] [-c <crit>]
#
# Config file format (sourced as shell):
#   CF_API_TOKEN=<token>
#   CF_ACCOUNT_ID=<account_id>

PROGNAME=$(basename "$0")
VERSION="1.0.0"

WARN_CONNS=2
CRIT_CONNS=1
CURL_TIMEOUT=10

print_usage() {
    cat <<EOF
Usage: $PROGNAME -T <tunnel_id> -f <config_file> [-w <warn>] [-c <crit>]
       $PROGNAME -T <tunnel_id> -t <api_token> -a <account_id> [-w <warn>] [-c <crit>]

Required:
  -T  Cloudflare Tunnel ID (UUID)
  -f  Config file with CF_API_TOKEN and CF_ACCOUNT_ID
  -t  Cloudflare API token (Bearer) (alternative to -f)
  -a  Cloudflare Account ID (alternative to -f)

Optional:
  -w  Warning threshold for connection count (default: $WARN_CONNS)
  -c  Critical threshold for connection count (default: $CRIT_CONNS)
  -h  Show this help message
  -V  Show version
EOF
}

TUNNEL_ID=""
API_TOKEN=""
ACCOUNT_ID=""
CONFIG_FILE=""

while getopts "T:t:a:f:w:c:hV" opt; do
    case "$opt" in
        T) TUNNEL_ID="$OPTARG" ;;
        t) API_TOKEN="$OPTARG" ;;
        a) ACCOUNT_ID="$OPTARG" ;;
        f) CONFIG_FILE="$OPTARG" ;;
        w) WARN_CONNS="$OPTARG" ;;
        c) CRIT_CONNS="$OPTARG" ;;
        h) print_usage; exit 3 ;;
        V) echo "$PROGNAME $VERSION"; exit 3 ;;
        *) print_usage; exit 3 ;;
    esac
done

if [ -n "$CONFIG_FILE" ]; then
    if [ ! -r "$CONFIG_FILE" ]; then
        echo "TUNNEL UNKNOWN - Cannot read config file: $CONFIG_FILE"
        exit 3
    fi
    eval "$(grep -E '^CF_(API_TOKEN|ACCOUNT_ID)=' "$CONFIG_FILE")"
    [ -z "$API_TOKEN" ] && API_TOKEN="$CF_API_TOKEN"
    [ -z "$ACCOUNT_ID" ] && ACCOUNT_ID="$CF_ACCOUNT_ID"
fi

if [ -z "$TUNNEL_ID" ] || [ -z "$API_TOKEN" ] || [ -z "$ACCOUNT_ID" ]; then
    echo "TUNNEL UNKNOWN - Missing required arguments (-T and either -f or -t/-a)"
    print_usage
    exit 3
fi

if ! [[ "$WARN_CONNS" =~ ^[0-9]+$ ]] || ! [[ "$CRIT_CONNS" =~ ^[0-9]+$ ]]; then
    echo "TUNNEL UNKNOWN - Thresholds must be non-negative integers"
    exit 3
fi

if [ "$WARN_CONNS" -lt "$CRIT_CONNS" ]; then
    echo "TUNNEL UNKNOWN - Warning threshold ($WARN_CONNS) must be >= critical threshold ($CRIT_CONNS)"
    exit 3
fi

for cmd in curl jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "TUNNEL UNKNOWN - Required command '$cmd' not found"
        exit 3
    fi
done

API_URL="https://api.cloudflare.com/client/v4/accounts/${ACCOUNT_ID}/cfd_tunnel/${TUNNEL_ID}"

HTTP_RESPONSE=$(curl -s -w "\n%{http_code}" \
    --max-time "$CURL_TIMEOUT" \
    -H "Authorization: Bearer ${API_TOKEN}" \
    -H "Content-Type: application/json" \
    "$API_URL" 2>&1)

CURL_EXIT=$?

if [ $CURL_EXIT -ne 0 ]; then
    echo "TUNNEL UNKNOWN - curl failed (exit $CURL_EXIT): $(echo "$HTTP_RESPONSE" | tail -1)"
    exit 3
fi

HTTP_CODE=$(echo "$HTTP_RESPONSE" | tail -1)
RESPONSE_BODY=$(echo "$HTTP_RESPONSE" | sed '$d')

if [ "$HTTP_CODE" -ne 200 ] 2>/dev/null; then
    API_ERRORS=$(echo "$RESPONSE_BODY" | jq -r '.errors[]?.message // "unknown error"' 2>/dev/null)
    echo "TUNNEL UNKNOWN - API returned HTTP $HTTP_CODE: $API_ERRORS"
    exit 3
fi

API_SUCCESS=$(echo "$RESPONSE_BODY" | jq -r '.success // false' 2>/dev/null)
if [ "$API_SUCCESS" != "true" ]; then
    API_ERRORS=$(echo "$RESPONSE_BODY" | jq -r '.errors[]?.message // "unknown error"' 2>/dev/null)
    echo "TUNNEL UNKNOWN - API error: $API_ERRORS"
    exit 3
fi

TUNNEL_STATUS=$(echo "$RESPONSE_BODY" | jq -r '.result.status // "unknown"' 2>/dev/null)
TUNNEL_NAME=$(echo "$RESPONSE_BODY" | jq -r '.result.name // "unknown"' 2>/dev/null)
CONN_COUNT=$(echo "$RESPONSE_BODY" | jq -r '.result.connections | length // 0' 2>/dev/null)
COLO_NAMES=$(echo "$RESPONSE_BODY" | jq -r '[.result.connections[]?.colo_name] | join(",")' 2>/dev/null)
ORIGIN_IPS=$(echo "$RESPONSE_BODY" | jq -r '[.result.connections[]?.origin_ip] | unique | join(",")' 2>/dev/null)

if ! [[ "$CONN_COUNT" =~ ^[0-9]+$ ]]; then
    echo "TUNNEL UNKNOWN - Failed to parse connection count from API response"
    exit 3
fi

PERFDATA="connections=${CONN_COUNT};${WARN_CONNS};${CRIT_CONNS};0"

if [ "$CONN_COUNT" -gt 0 ]; then
    CONN_DETAIL="${CONN_COUNT} connection"
    [ "$CONN_COUNT" -ne 1 ] && CONN_DETAIL="${CONN_DETAIL}s"
    CONN_DETAIL="${CONN_DETAIL} (${COLO_NAMES})"
    [ -n "$ORIGIN_IPS" ] && CONN_DETAIL="${CONN_DETAIL} from ${ORIGIN_IPS}"
else
    CONN_DETAIL="0 connections"
fi

if [ "$TUNNEL_STATUS" != "healthy" ]; then
    echo "TUNNEL CRITICAL - ${TUNNEL_NAME} status '${TUNNEL_STATUS}', ${CONN_DETAIL} | ${PERFDATA}"
    exit 2
fi

if [ "$CONN_COUNT" -le "$CRIT_CONNS" ]; then
    echo "TUNNEL CRITICAL - ${CONN_DETAIL} | ${PERFDATA}"
    exit 2
elif [ "$CONN_COUNT" -le "$WARN_CONNS" ]; then
    echo "TUNNEL WARNING - ${CONN_DETAIL} | ${PERFDATA}"
    exit 1
else
    echo "TUNNEL OK - ${CONN_DETAIL} | ${PERFDATA}"
    exit 0
fi
